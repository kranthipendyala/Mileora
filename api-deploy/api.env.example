CI_ENV=production

# --- Database ---
DB_HOSTNAME=db.your-managed-host.example
DB_PORT=3306
DB_USERNAME=mileora_app
DB_PASSWORD=replace-me
DB_DATABASE=mileora
DB_CHARSET=utf8mb4
DB_COLLAT=utf8mb4_unicode_ci

# --- JWT ---
JWT_SECRET=replace-with-256-bit-random
JWT_ISSUER=mileora.com
JWT_TTL_SECONDS=86400

# --- Server-to-server key (Next.js BFF → CI3) ---
MILEORA_SERVER_API_KEY=replace-with-random-32+chars

# --- Razorpay ---
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxx

# --- Elasticsearch ---
ES_HOSTS=https://your-cluster.es.io:9243
ES_USERNAME=elastic
ES_PASSWORD=replace-me
ES_INDEX_PREFIX=mileora_

# --- Firebase Cloud Messaging (push) ---
FCM_PROJECT_ID=mileora-prod
FCM_SA_PATH=/var/www/api/secrets/fcm-sa.json

# --- Mail ---
MAIL_FROM=info@magnusconference.com
MAIL_FROM_NAME=Mileora
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# --- SMS / WhatsApp ---
SMS_PROVIDER=msg91
SMS_API_KEY=

# --- Public site URL (used in emails, redirects) ---
SITE_URL=https://mileora.com
