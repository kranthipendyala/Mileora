{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "regions": ["bom1"],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Edge-Region", "value": "bom1" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/proxy?path=:path*" }
  ]
}
