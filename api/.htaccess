<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /Mileora/api/

    # Block access to system + application
    RewriteRule ^(application|system|vendor)($|/) - [F,L]

    # Allow real files & dirs
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Hand everything else to index.php
    RewriteRule ^(.*)$ index.php/$1 [L,QSA]
</IfModule>

# Deny direct access to env file
<Files .env>
    Order allow,deny
    Deny from all
</Files>
