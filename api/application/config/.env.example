CI_ENV=development

# --- Database (XAMPP defaults shown) ---
DB_HOSTNAME=127.0.0.1
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=mileora
DB_CHARSET=utf8mb4
DB_COLLAT=utf8mb4_unicode_ci

# --- JWT ---
JWT_SECRET=replace-with-256-bit-random
JWT_ISSUER=mileora.com
JWT_TTL_SECONDS=86400

# --- Server-to-server key (Next.js BFF -> CI3) ---
MILEORA_SERVER_API_KEY=replace-with-random-32+chars

# --- Razorpay ---
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxx

# --- Elasticsearch ---
ES_HOSTS=http://localhost:9200
ES_USERNAME=
ES_PASSWORD=
ES_INDEX_PREFIX=mileora_

# --- Mail (transactional) ---
MAIL_FROM=info@magnusconference.com
MAIL_FROM_NAME=Mileora
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# --- WhatsApp / SMS (optional, e.g. via MSG91) ---
SMS_PROVIDER=msg91
SMS_API_KEY=

# --- Public site URL (used in emails, redirects) ---
SITE_URL=http://localhost:3000
