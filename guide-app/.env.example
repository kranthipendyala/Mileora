# Android emulator: 10.0.2.2 maps to the host machine
# iOS simulator: localhost
# Physical device on same Wi-Fi: your machine's LAN IP (e.g. 192.168.1.10)
EXPO_PUBLIC_API_URL=http://10.0.2.2/Mileora/api/index.php/api/v1

# App-side key for unauthenticated calls (registration, password-reset, etc.)
# Note: bundled into the app, not truly secret. Rotate periodically.
EXPO_PUBLIC_MILEORA_APP_KEY=replace-with-random-32+chars

# OneSignal / Firebase push (filled when you wire push notifications)
EXPO_PUBLIC_ONESIGNAL_APP_ID=
