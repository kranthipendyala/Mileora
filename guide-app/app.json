{
  "expo": {
    "name": "Mileora Guide",
    "slug": "mileora-guide",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "mileoraguide",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0b0a14"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mileora.guide"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0b0a14"
      },
      "package": "com.mileora.guide"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": ["expo-router", "expo-font"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": { "origin": false }
    }
  }
}
