{
  "settings": {
    "number_of_shards": 1,
    "number_of_replicas": 1,
    "analysis": {
      "analyzer": {
        "mileora_text": {
          "tokenizer": "standard",
          "filter": ["lowercase", "asciifolding", "english_stop", "english_stemmer"]
        }
      },
      "filter": {
        "english_stop":   { "type": "stop",     "stopwords": "_english_" },
        "english_stemmer": { "type": "stemmer", "language": "english" }
      }
    }
  },
  "mappings": {
    "properties": {
      "id":           { "type": "keyword" },
      "slug":         { "type": "keyword" },
      "title":        { "type": "text", "analyzer": "mileora_text",
                        "fields": { "raw": { "type": "keyword" } } },
      "excerpt":      { "type": "text", "analyzer": "mileora_text" },
      "body":         { "type": "text", "analyzer": "mileora_text" },
      "category":     { "type": "keyword" },
      "tags":         { "type": "keyword" },
      "cover_url":    { "type": "keyword", "index": false },
      "author":       { "type": "keyword" },
      "published_at": { "type": "date" },
      "status":       { "type": "keyword" }
    }
  }
}
