# Use 10.0.2.2 for Android emulator -> host machine
# Use your LAN IP (e.g. 192.168.1.10) for physical devices on the same Wi-Fi
EXPO_PUBLIC_API_URL=http://10.0.2.2/Mileora/api/index.php/api/v1

# Public Razorpay key (matches CI3 .env RAZORPAY_KEY_ID)
EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# Server-key for app-side anonymous calls (lead capture etc.)
# Note: bundled into the app, not truly secret. Rotate periodically.
EXPO_PUBLIC_MILEORA_APP_KEY=replace-with-random-32+chars
