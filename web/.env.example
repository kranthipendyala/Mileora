# Public site URL (used for canonical URLs, sitemap, OG)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# CodeIgniter 3 API base
NEXT_PUBLIC_API_URL=http://localhost/Mileora/api/index.php/api/v1

# Server-only key for BFF → CI3 calls (lead capture etc.). NEVER prefix with NEXT_PUBLIC_.
MILEORA_SERVER_API_KEY=replace-with-random-32+chars

# Razorpay (public key id is exposed to browser; secret stays on CI3 backend)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# Optional: analytics
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
